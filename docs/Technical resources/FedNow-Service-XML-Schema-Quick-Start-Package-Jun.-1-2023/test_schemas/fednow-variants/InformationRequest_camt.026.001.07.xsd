            <xs:element name="Undrlyg" type="UnderlyingTransaction5Choice__1">
                <xs:annotation>
                    <xs:documentation source="Name" xml:lang="EN">Underlying</xs:documentation>
                    <xs:documentation source="Definition" xml:lang="EN">References the payment instruction or statement entry that a party is unable to execute or unable to reconcile.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Justfn" type="UnableToApplyJustification3Choice__1">
                <xs:annotation>
                    <xs:documentation source="Name" xml:lang="EN">Justification</xs:documentation>
                    <xs:documentation source="Definition" xml:lang="EN">Explains the reason why the case creator is unable to apply the instruction.</xs:documentation>
