    <xs:simpleType name="ConnectionPartyIdentifier_FedNow_1">
        <xs:annotation>
            <xs:documentation source="Name" xml:lang="EN">ConnectionPartyIdentifier_FedNow_1</xs:documentation>
            <xs:documentation source="Definition" xml:lang="EN">The Connection Party Identifier identifies the organization that maintains an electronic connection to the FedNow Service through which that organization may send or receive messages for itself or on behalf of a FedNow participant. This may be a routing number (RTN), an Electronic Transaction Identifier (ETI), or an identifier defined by the FedNow Service. </xs:documentation>
