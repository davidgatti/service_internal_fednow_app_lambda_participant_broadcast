  </xs:complexType>
  <xs:simpleType name="ConnectionPartyIdentifier_FedNow_1">
    <xs:annotation>
      <xs:documentation source="Name" xml:lang="EN">ConnectionPartyIdentifier_FedNow_1</xs:documentation>
      <xs:documentation source="Definition" xml:lang="EN">The Connection Party Identifier identifies the organization that maintains an electronic connection to the FedNow Service through which that organization may send or receive messages for itself or on behalf of a FedNow participant. This may be a routing number (RTN), an Electronic Transaction Identifier (ETI), or an identifier defined by the FedNow Service. </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:string">
      <xs:pattern value="[A-Z0-9]{9,9}"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="CopyDuplicate1Code__1">
    <xs:annotation>
      <xs:documentation source="Name" xml:lang="EN">CopyDuplicate1Code__1</xs:documentation>
      <xs:documentation source="Definition" xml:lang="EN">Specifies if this document is a copy, a duplicate, or a duplicate of a copy.</xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="DUPL">
        <xs:annotation>
          <xs:documentation source="Name" xml:lang="EN">Duplicate</xs:documentation>
          <xs:documentation source="Definition" xml:lang="EN">Message is for information/confirmation purposes. It is a duplicate of a message previously sent.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
    </xs:restriction>
  </xs:simpleType>
  <xs:complexType name="FinancialInstitutionIdentification18__1">
    <xs:annotation>
      <xs:documentation source="Name" xml:lang="EN">FinancialInstitutionIdentification18__1</xs:documentation>
