{
  "scripts": {
    "locally": "env $(cat .env) node -e \"require('./.loader.js')\"",
    "lint": "npm run lint:eslint && npm run lint:md && npm run lint:knip",
    "lint:eslint": "eslint --fix .",
    "lint:md": "markdownlint-cli2 --fix \"**/*.md\" \"!node_modules\"",
    "lint:knip": "knip",
    "test": "jest --runInBand --coverage",
    "tool:upgrade": "npx npm-check-updates -u && npm install && npm audit fix && npm install -g npm@latest && npm run lint && npm run test"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1020.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-rulesdir": "^0.2.2",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "knip": "^6.1.1",
    "markdownlint-cli2": "^0.22.0",
    "pino-pretty": "^13.1.3"
  }
}
